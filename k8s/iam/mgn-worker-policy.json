{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MGNFullAccess",
      "Effect": "Allow",
      "Action": "mgn:*",
      "Resource": "*"
    },
    {
      "Sid": "EC2MigrationSupport",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:TerminateInstances",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSubnets",
        "ec2:DescribeLaunchTemplates",
        "ec2:CreateLaunchTemplateVersion",
        "ec2:RunInstances"
      ],
      "Resource": "*"
    }
  ]
}
