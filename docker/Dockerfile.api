# Image for the Orchestrator API (FastAPI + uvicorn).
#
# Build from the project root:
#   docker build -f docker/Dockerfile.api -t migration-orchestrator/api:latest .

FROM python:3.12-slim

WORKDIR /app/src

# Install dependencies first (cached layer unless requirements.txt changes)
COPY src/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy all source code
COPY src/ ./

EXPOSE 8000

CMD ["python", "-m", "api.run_api"]
